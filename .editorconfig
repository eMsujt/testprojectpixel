# EditorConfig — https://editorconfig.org
# Top-level config for the SkyBlock Maven multi-module project.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{java,xml}]
indent_size = 4

[*.{yml,yaml,json}]
indent_size = 2

[*.md]
# Trailing whitespace is significant (hard line breaks) in Markdown.
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
